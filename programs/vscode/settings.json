// Depends on the project's comment out or uncomment the relevant lines,
// For example, uncomment black and isort if you are using them instead of
// ruff for formatting and linting.
{
  // HTML, JavaScript, TypeScript Settings
  "[html,javascript,typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.indentSize": "tabSize",
    "editor.tabSize": 2,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  // Python Settings
  "[python]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    },
    // "editor.defaultFormatter": "ms-python.black-formatter"
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  // "isort.args": ["--profile", "black"],
  // "python.analysis.fixAll": ["source.unusedImports"],
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,

  // Linting settings
  "python.analysis.languageServerMode": "light",
  "python.analysis.typeCheckingMode": "off",
  "python.analysis.indexing": true,

  // Extensions Settings
  // Ruff
  "ruff.lineLength": 79,

  // Spell Checker
  "cSpell.words": [
    "dotenv",
    "inlinehilite",
    "linenums",
    "mkdocs",
    "mkdocstrings",
    "mypy",
    "pydantic",
    "pygments",
    "pymdownx",
    "Pytest",
    "pythonpath",
    "superfences",
    "testpaths",
    "venv",
    "excinfo",
    "stackoverflow",
    "levelname",
    "sessionstart",
    "isort",
    "pylint",
    "conftest",
    "dataclass",
    "pluggy",
    "abstractmethods"
  ],
  "cSpell.ignorePaths": [
        ".vscode",
        ".github",
        ".git",
        ".gitignore",
        "dist",
        "site",
        "build",
        "uv.lock"
  ],
  "cSpell.customDictionaries": {
    "custom-dictionary-workspace": {
      "name": "custom-dictionary-workspace",
      "path": "${workspaceFolder:uynab}/.cspell/custom-dictionary-workspace.txt",
      "addWords": true,
      "scope": "workspace"
    }
  },

  // Git Blame
  "git.blame.editorDecoration.enabled": true,
  "git.blame.editorDecoration.template": "${authorName}: ${subject}, ${authorDateAgo}",

  // General VSCode Settings
  "files.exclude": {},
  "editor.rulers": [79, 88, 100],
  "workbench.colorTheme": "Default Light Modern",
  "editor.fontFamily": "'MesloLGS Nerd Font', 'MesloLGS Nerd Font', monospace",
  // "editor.folding": false
  "diffEditor.hideUnchangedRegions.enabled": false,
  "editor.minimap.enabled": false,
  "files.trimTrailingWhitespace": true,

  // Terminal settings
  "terminal.integrated.fontFamily": "CaskaydiaMono Nerd Font Mono",
  "terminal.integrated.fontSize": 16

  // Powershell Terminal Theme
  // "workbench.colorCustomizations": {
